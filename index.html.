<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Celengan Digital - Catatan Tabungan</title>
    <style>
        /* Gaya Tampilan Finansial Modern (Clean & Soft Blue) */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: #f4f7f6;
            color: #333333;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            background: #ffffff;
            width: 100%;
            max-width: 400px;
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        h1 {
            font-size: 1.3rem;
            text-align: center;
            color: #1a365d;
            margin-bottom: 20px;
            font-weight: 700;
        }

        /* Card Saldo Utama */
        .card-saldo {
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            color: white;
            border-radius: 18px;
            padding: 25px 20px;
            text-align: center;
            margin-bottom: 25px;
            box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
        }

        .card-saldo p {
            font-size: 0.9rem;
            opacity: 0.8;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .saldo-angka {
            font-size: 2.2rem;
            font-weight: 700;
        }

        /* Form Input */
        .input-group {
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #4a5568;
            margin-bottom: 8px;
        }

        .input-group input {
            width: 100%;
            padding: 14px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 1.1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-group input:focus {
            border-color: #3b82f6;
        }

        /* Tombol Aksi */
        .action-buttons {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
        }

        .btn {
            flex: 1;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.1s, opacity 0.2s;
            color: white;
            -webkit-tap-highlight-color: transparent;
        }

        .btn:active {
            transform: scale(0.97);
        }

        .btn-masuk {
            background-color: #10b981; /* Hijau */
        }

        .btn-keluar {
            background-color: #ef4444; /* Merah */
        }

        /* Riwayat Transaksi */
        .riwayat-section {
            border-top: 2px solid #f1f5f9;
            padding-top: 20px;
        }

        .riwayat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .riwayat-header h3 {
            font-size: 1rem;
            color: #1a365d;
        }

        .btn-reset {
            background: none;
            border: none;
            color: #94a3b8;
            font-size: 0.85rem;
            cursor: pointer;
            font-weight: 500;
        }

        .btn-reset:hover {
            color: #ef4444;
        }

        .list-riwayat {
            list-style: none;
            max-height: 200px;
            overflow-y: auto;
            padding-right: 5px;
        }

        .item-riwayat {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            background: #f8fafc;
            border-radius: 10px;
            margin-bottom: 8px;
            font-size: 0.9rem;
            border-left: 4px solid #cbd5e1;
        }

        .item-riwayat.masuk {
            border-left-color: #10b981;
        }

        .item-riwayat.keluar {
            border-left-color: #ef4444;
        }

        .info-riwayat .tgl {
            font-size: 0.75rem;
            color: #94a3b8;
            display: block;
            margin-top: 2px;
        }

        .nominal-riwayat {
            font-weight: 600;
        }

        .nominal-riwayat.masuk { color: #10b981; }
        .nominal-riwayat.keluar { color: #ef4444; }

        .empty-state {
            text-align: center;
            color: #94a3b8;
            font-size: 0.9rem;
            padding: 20px 0;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Celengan Digital</h1>

        <!-- Tampilan Saldo -->
        <div class="card-saldo">
            <p>Total Tabungan Saya</p>
            <div class="saldo-angka" id="totalSaldo">Rp 0</div>
        </div>

        <!-- Input Jumlah Uang -->
        <div class="input-group">
            <label for="jumlahUang">Masukkan Nominal (Rp)</label>
            <input type="number" id="jumlahUang" placeholder="Contoh: 20000" min="1">
        </div>

        <!-- Tombol Menabung / Menarik -->
        <div class="action-buttons">
            <button class="btn btn-masuk" onclick="prosesTransaksi('masuk')">Nabung (+)</button>
            <button class="btn btn-keluar" onclick="prosesTransaksi('keluar')">Tarik (-)</button>
        </div>

        <!-- Daftar Riwayat -->
        <div class="riwayat-section">
            <div class="riwayat-header">
                <h3>Riwayat Transaksi</h3>
                <button class="btn-reset" onclick="resetData()">Hapus Semua</button>
            </div>
            <ul class="list-riwayat" id="listRiwayat">
                <!-- Data transaksi akan muncul di sini via JS -->
            </ul>
        </div>
    </div>

    <script>
        // Inisialisasi data dari localStorage atau buat baru jika kosong
        let saldo = localStorage.getItem('saldoTabungan') ? parseInt(localStorage.getItem('saldoTabungan')) : 0;
        let riwayat = localStorage.getItem('riwayatTabungan') ? JSON.parse(localStorage.getItem('riwayatTabungan')) : [];

        const domSaldo = document.getElementById('totalSaldo');
        const domInput = document.getElementById('jumlahUang');
        const domList = document.getElementById('listRiwayat');

        // Format angka ke format mata uang Rupiah (IDR)
        function formatRupiah(angka) {
            return 'Rp ' + angka.toLocaleString('id-ID');
        }

        // Fungsi memperbarui UI/Layar
        function updateLayar() {
            domSaldo.textContent = formatRupiah(saldo);
            localStorage.setItem('saldoTabungan', saldo);
            localStorage.setItem('riwayatTabungan', JSON.stringify(riwayat));

            // Bersihkan daftar riwayat lama
            domList.innerHTML = '';

            if (riwayat.length === 0) {
                domList.innerHTML = '<li class="empty-state">Belum ada riwayat menabung.</li>';
                return;
            }

            // Urutkan dari yang paling baru di atas
            riwayat.forEach(item => {
                const li = document.createElement('li');
                li.className = `item-riwayat ${item.jenis}`;
                
                li.innerHTML = `
                    <div class="info-riwayat">
                        <strong>${item.jenis === 'masuk' ? 'Menabung' : 'Tarik Uang'}</strong>
                        <span class="tgl">${item.waktu}</span>
                    </div>
                    <div class="nominal-riwayat ${item.jenis}">
                        ${item.jenis === 'masuk' ? '+' : '-'} ${formatRupiah(item.nominal)}
                    </div>
                `;
                domList.appendChild(li);
            });
        }

        // Fungsi untuk menangani proses menabung atau menarik uang
        function prosesTransaksi(jenis) {
            const nominal = parseInt(domInput.value);

            // Validasi input
            if (isNaN(nominal) || nominal <= 0) {
                alert('Silakan masukkan nominal uang yang valid!');
                return;
            }

            if (jenis === 'keluar' && nominal > saldo) {
                alert('Saldo tabungan kamu tidak cukup untuk melakukan penarikan!');
                return;
            }

            // Hitung perubahan saldo
            if (jenis === 'masuk') {
                saldo += nominal;
            } else {
                saldo -= nominal;
            }

            // Ambil waktu saat ini
            const opsiWaktu = { dateStyle: 'medium', timeStyle: 'short' };
            const waktuSekarang = new Date().toLocaleString('id-ID', opsiWaktu);

            // Masukkan data ke array riwayat (posisi paling depan)
            riwayat.unshift({
                jenis: jenis,
                nominal: nominal,
                waktu: waktuSekarang
            });

            // Reset field input
            domInput.value = '';

            // Update database lokal & layar
            updateLayar();
        }

        // Fungsi mengosongkan celengan kembali ke 0
        function resetData() {
            if (confirm('Apakah kamu yakin ingin mengosongkan seluruh catatan celengan ini?')) {
                saldo = 0;
                riwayat = [];
                updateLayar();
            }
        }

        // Jalankan render layar pertama kali saat web dibuka
        updateLayar();
    </script>
</body>
</html>
